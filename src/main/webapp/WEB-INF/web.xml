<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Transaction Limit Management</display-name>

    <servlet>
        <servlet-name>SignupServlet</servlet-name>
        <servlet-class>com.transaction.controller.SignupServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>SignupServlet</servlet-name>
        <url-pattern>/signup</url-pattern>
    </servlet-mapping>
	
	<servlet>
    <servlet-name>LoginServlet</servlet-name>
    <servlet-class>com.transaction.controller.LoginServlet</servlet-class>
    </servlet>

    <servlet-mapping>
    <servlet-name>LoginServlet</servlet-name>
    <url-pattern>/login</url-pattern>
    </servlet-mapping>
	
	<servlet>
    <servlet-name>LogoutServlet</servlet-name>
    <servlet-class>com.transaction.controller.LogoutServlet</servlet-class>
    </servlet>

    <servlet-mapping>
    <servlet-name>LogoutServlet</servlet-name>
    <url-pattern>/logout</url-pattern>
    </servlet-mapping>
	
	<servlet>
    <servlet-name>AccountServlet</servlet-name>
    <servlet-class>com.transaction.controller.AccountServlet</servlet-class>
    </servlet>

    <servlet-mapping>
    <servlet-name>AccountServlet</servlet-name>
    <url-pattern>/account/create</url-pattern>
    </servlet-mapping>
	
	<filter>
    <filter-name>AuthFilter</filter-name>
    <filter-class>com.transaction.filter.AuthFilter</filter-class>
    </filter>

    <filter-mapping>
    <filter-name>AuthFilter</filter-name>
    <url-pattern>/account/*</url-pattern>
    </filter-mapping>

    <filter-mapping>
    <filter-name>AuthFilter</filter-name>
    <url-pattern>/transactions/*</url-pattern>
    </filter-mapping>

    <filter>
        <filter-name>RoleFilter</filter-name>
        <filter-class>com.transaction.filter.RoleFilter</filter-class>
    </filter>

    <filter-mapping>
        <filter-name>RoleFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>

</web-app>